@startuml DDD ER Diagram

skinparam class {
  BackgroundColor<<AR>>     #FFEAA7
  BorderColor<<AR>>         #E17055
  FontStyle<<AR>>           Bold

  BackgroundColor<<Entity>> #DFE6E9
  BorderColor<<Entity>>     #636E72

  BackgroundColor<<VO>>     #D5F5E3
  BorderColor<<VO>>         #27AE60
}

skinparam package {
  BackgroundColor #FAFAFA
  BorderColor     #95A5A6
  FontStyle       Bold
  FontSize        13
}

skinparam arrow {
  Color           #2D3436
  FontSize        10
}

hide empty members

legend top right
  |<#FFEAA7> AR  | Aggregate Root |
  |<#DFE6E9> E   | Entity         |
  |<#D5F5E3> VO  | Value Object   |
endlegend

' ══════════════════════════════════════
package "BC: Контекст планирования" #FFF9E6 {

  class "Данные\nпланирования" <<VO>> {
    Название мультипроекта : String
    Горизонт планирования  : Date
  }

  class "Портфельные\nограничения" <<VO>> {
    Лимит аналитики    : Int
    Лимит разработчики : Int
    Лимит тестировщики : Int
    Критический срок   : Date
  }

  class "Стратегические\nориентиры" <<AR>> {
  }

  class "Ориентир" <<Entity>> {
    Видение   : String
    Приоритет : Высокий | Средний | Низкий
  }

  class "Реестр\nпроектов" <<AR>> {
  }

  class "Проект" <<Entity>> {
    Название              : String
    Статус                : Завершено | В работе | Не начато
    Дата начала           : Date
    Дата окончания        : Date
    Трудоемкость аналитики    : Int
    Трудоемкость разработчики : Int
    Трудоемкость тестировщики : Int
    Ограничения проекта   : String
    Текущие отклонения    : String
    Описание проекта      : String
  }

  class "Зависимости\nпроектов" <<AR>> {
  }

  class "Зависимость" <<Entity>> {
    Описание связи : String
  }

  "Стратегические\nориентиры"  *--  "Ориентир"           : содержит >
  "Реестр\nпроектов"           *--  "Проект"             : содержит >
  "Зависимости\nпроектов"      *--  "Зависимость"        : содержит >
  "Зависимость"               -->  "Проект"             : основной >
  "Зависимость"               -->  "Проект"             : зависимый >
}

' ══════════════════════════════════════
package "BC: Анализ портфеля" #E8F4FD {

  class "Риски\nанализа" <<AR>> {
  }

  class "Риск\nанализа" <<Entity>> {
    Риск     : String
    Влияние  : Низкий | Средний | Высокий
    Источник : String
  }

  class "Анализ текущих\nотклонений" <<AR>> {
  }

  class "Отклонение" <<Entity>> {
    Проект                : String
    Отклонение            : String
    Опасность для портфеля : Низкая | Средняя | Высокая
    Передача по зависимостям : String
  }

  class "Реализуемость портфеля\nпо срокам" <<VO>> {
    Описание : String
  }

  class "Загрузка и дефицит\nресурсов по ролям" <<VO>> {
    Роль               : String
    Суммарная потребность : Int
    Лимит              : Int
    Дефицит/Профицит   : Int
  }

  class "ИИ-объяснения" <<VO>> {
    Описание : String
  }

  class "ИИ-рекомендации" <<VO>> {
    Заголовок : String
    Текст     : String
  }

  "Риски\nанализа"             *--  "Риск\nанализа"      : содержит >
  "Анализ текущих\nотклонений" *--  "Отклонение"         : содержит >
}

' ══════════════════════════════════════
package "BC: Стратегические цели" #FFFDE7 {

  class "Список\nцелей" <<AR>> {
  }

  class "Цель" <<Entity>> {
    Specific           : String
    Название KPI       : String
    Целевое значение   : Number
    Единица измерения  : String
    Achievable         : String
    Timebound          : Date
    Приоритет          : Высокий | Средний | Низкий
    Контекст           : ИИ | Пользователь
    Пояснение ИИ       : String
  }

  class "Список конфликтов\nцелей" <<AR>> {
  }

  class "Конфликт\nцелей" <<Entity>> {
    Категория  : String
    Описание   : String
  }

  class "Дублирование\nцелей" <<AR>> {
  }

  class "Дубль\nцелей" <<Entity>> {
    Категория  : String
    Описание   : String
  }

  class "Покрытие\nпроектами" <<VO>> {
    Степень покрытия : Слабое | Умеренное | Сильное
  }

  class "Проверка реалистичности\nцели" <<VO>> {
    Степень реалистичности : Низкая | Средняя | Высокая
    Оценка реалистичности  : Int [0..100]
    Формулировка           : Boolean
    Измеримость            : Boolean
    KPI                    : Boolean
    Достижимость           : Boolean
    Срок                   : Boolean
    Стратегические ориентиры : Boolean
    Связанные проекты      : Boolean
  }

  class "Цели,\nпредложенные ИИ" <<VO>> {
    Список целей : List<Цель>
  }

  "Список\nцелей"               *--  "Цель"                          : содержит >
  "Список конфликтов\nцелей"    *--  "Конфликт\nцелей"               : содержит >
  "Дублирование\nцелей"         *--  "Дубль\nцелей"                  : содержит >
  "Конфликт\nцелей"             -->  "Цель"                          : вовлекает >
  "Дубль\nцелей"                -->  "Цель"                          : дублирует >
  "Цель"                       *--  "Покрытие\nпроектами"            : имеет >
  "Цель"                       *--  "Проверка реалистичности\nцели"  : имеет >
}

' ══════════════════════════════════════
package "BC: Альтернативы" #FDEDEC {

  class "Альтернативы" <<AR>> {
  }

  class "Сценарий" <<Entity>> {
    Название              : String
    Тип                   : Сбалансированный | Консервативный | Рискованный
    Описание              : String
    Статус                : Допустимый | Рекомендуемый | Требует внимания
    Интегральная оценка   : Int [0..100]
    Общий срок            : Int (мес)
    Количество рисков     : Int
    Соблюдение ограничений : Int (%)
    Сильные стороны       : List<String>
    Слабые стороны        : List<String>
    ИИ-интерпретация      : String
    Выбор для плана       : Boolean
  }

  class "Риски\nсценария" <<AR>> {
  }

  class "Риск\nсценария" <<Entity>> {
    Риск     : String
    Влияние  : Низкий | Средний | Высокий
    Источник : String
  }

  class "Матрица сравнения\nальтернатив" <<VO>> {
    Интегральная оценка     : Int [0..100]
    Количество рисков       : Int
    Соблюдение ограничений  : Int (%)
    Ресурсная реализуемость : Int (%)
    Общий срок              : Int (мес)
    Статус                  : String
  }

  "Альтернативы"    *--  "Сценарий"          : содержит >
  "Сценарий"        *--  "Риски\nсценария"   : содержит >
  "Риски\nсценария" *--  "Риск\nсценария"    : содержит >
}

' ══════════════════════════════════════
package "BC: Стратегический план" #F0F0F0 {

  class "План" <<AR>> {
  }

  class "Этап" <<Entity>> {
    Номер этапа  : Int
    Название     : String
    Период       : String
    Статус этапа : Выполнен | В работе | Планируется
  }

  class "Контрольная\nточка" <<Entity>> {
    Название : String
    Дата     : Date
    Статус   : Достигнута | Запланирована
  }

  class "Риски\nплана" <<AR>> {
  }

  class "Риск\nплана" <<Entity>> {
    Риск     : String
    Влияние  : Низкий | Средний | Высокий
    Источник : String
  }

  class "Состав\nэтапа" <<VO>> {
    Проект : String
    Доля   : Int (%)
    Ресурс : String
  }

  class "Ресурсы\nэтапа" <<VO>> {
    Роль           : Аналитики | Разработчики | Тестировщики
    Требуется      : Int (ч/ч)
    Доступно       : Int (ч/ч)
    Загрузка       : Int (%)
    Степень загрузки : Низкая | Средняя | Высокая | Критичная
  }

  class "Паспорт стратегического\nплана" <<VO>> {
    Выбранный вариант        : String
    Плановый горизонт        : Int (мес)
    Контрольных точек        : Int
    Рисков                   : Int
    Ограничения в зоне внимания : Int
    Прогресс выполнения      : Int (%)
  }

  class "Состояние этапов\nпланирования" <<VO>> {
    Название : String
    Статус   : Завершено | В процессе | Не начато
  }

  "План"            *--  "Этап"                          : содержит >
  "Этап"            *--  "Контрольная\nточка"            : завершается >
  "Этап"            *--  "Состав\nэтапа"                 : включает >
  "Этап"            *--  "Ресурсы\nэтапа"                : требует >
  "План"            *--  "Риски\nплана"                  : содержит >
  "Риски\nплана"    *--  "Риск\nплана"                   : содержит >
  "План"            *--  "Паспорт стратегического\nплана" : сводка >
}

' ══════════════════════════════════════
' Cross-BC dependencies (dashed)
' ══════════════════════════════════════

"Реестр\nпроектов"           ..>  "Анализ текущих\nотклонений"         : данные
"Реестр\nпроектов"           ..>  "Риски\nанализа"                     : данные
"Зависимости\nпроектов"      ..>  "Риски\nанализа"                     : данные
"Портфельные\nограничения"   ..>  "Риски\nанализа"                     : данные
"Портфельные\nограничения"   ..>  "Загрузка и дефицит\nресурсов по ролям" : данные

"Реестр\nпроектов"           ..>  "Цель"                               : связанные проекты
"Стратегические\nориентиры"  ..>  "Цель"                               : Relevant

"Реестр\nпроектов"           ..>  "Альтернативы"                       : данные
"Зависимости\nпроектов"      ..>  "Альтернативы"                       : данные
"Портфельные\nограничения"   ..>  "Альтернативы"                       : ограничения

"Сценарий"                   ..>  "План"                               : основа плана
"Реестр\nпроектов"           ..>  "Состав\nэтапа"                      : проекты
"Портфельные\nограничения"   ..>  "Ресурсы\nэтапа"                     : лимиты

@enduml
